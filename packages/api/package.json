{
	"name": "@nexus/api",
	"version": "0.1.0",
	"type": "module",
	"exports": {
		".": {
			"default": "./src/index.ts"
		},
		"./routers": {
			"default": "./src/routers/index.ts"
		},
		"./routers/iou": {
			"default": "./src/routers/iou.ts"
		},
		"./context": {
			"default": "./src/context.ts"
		},
		"./*": {
			"default": "./src/*.ts"
		}
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"lint": "biome lint .",
		"build": "tsc"
	},
	"dependencies": {
		"@nexus/auth": "workspace:*",
		"@nexus/db": "workspace:*",
		"@nexus/env": "workspace:*",
		"@nexus-framework/core": "workspace:*",
		"@orpc/client": "catalog:",
		"@orpc/openapi": "catalog:",
		"@orpc/server": "catalog:",
		"@orpc/zod": "catalog:",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@nexus/config": "workspace:*",
		"@types/node": "catalog:",
		"typescript": "catalog:"
	}
}
