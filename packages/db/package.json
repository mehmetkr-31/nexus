{
	"name": "@nexus-framework/db",
	"version": "0.1.0",
	"type": "module",
	"exports": {
		".": {
			"default": "./src/index.ts"
		},
		"./*": {
			"default": "./src/*.ts"
		}
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"lint": "biome lint .",
		"build": "tsc",
		"db:local": "turso dev --db-file local.db",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:studio": "drizzle-kit studio",
		"db:migrate": "drizzle-kit migrate"
	},
	"dependencies": {
		"@libsql/client": "catalog:",
		"@nexus-framework/env": "workspace:*",
		"dotenv": "catalog:",
		"drizzle-orm": "^0.45.1",
		"libsql": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@nexus-framework/config": "workspace:*",
		"@types/node": "catalog:",
		"drizzle-kit": "^0.31.8",
		"typescript": "catalog:"
	}
}
