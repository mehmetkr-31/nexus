		"picocolors": "^1.1.1"
	},
	"devDependencies": {
		"@types/fs-extra": "^11.0.4",
		"@types/node": "^22.13.5",
		"tsup": "^8.3.6",
		"typescript": "^5.7.3"
	}
}
