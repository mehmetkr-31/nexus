{
	"name": "nexus",
	"type": "module",
	"packageManager": "bun@1.3.5",
	"workspaces": [
		"packages/*",
		"apps/*",
		"sandbox"
	],
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@types/bun": "latest",
		"turbo": "^2.8.21",
		"typescript": "^5"
	},
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"test": "turbo test",
		"typecheck": "turbo typecheck",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "turbo typecheck && biome check --fix",
		"check:fix": "biome check --write .",
		"ci": "biome ci ."
	},
	"dependencies": {
		"300": "^0.0.1",
		"better-auth": "^1.5.6"
	}
}
